{
    "name": "pact-foundation/pact-php",
    "keywords": [
        "pact",
        "pact-php"
    ],
    "homepage": "https://github.com/pact-foundation/pact-php",
    "description": "Enables consumer driven contract testing, following the PACT foundation principles.",
    "license": "MIT",
    "authors": [
        {
            "name": "Mattermack",
            "email": "c.f.mack@gmail.com"
        },
        {
            "name": "Nicholas Brink",
            "email": "nick.brink@mattersight.com"
        }
    ],
    "require": {
        "php": "^7.4|^8.0|^8.1",
        "ext-json": "*",
        "symfony/process": "^4.4|^5.4|^6.0",
        "guzzlehttp/guzzle": "^6.5.8|^7.4.5",
        "phpunit/phpunit": ">=8.5.23",
        "civicrm/composer-downloads-plugin": "dev-all"
    },
    "require-dev": {
        "roave/security-advisories": "dev-latest",
        "slim/slim": "^4.6",
        "slim/psr7": "^1.2.0",
        "friendsofphp/php-cs-fixer": "^3.0",
        "php-amqplib/php-amqplib": "^3.0",
        "phpstan/phpstan": "^1.8",
        "google/protobuf": "^3.19"
    },
    "repositories" : [
        {
            "type": "vcs",
            "url": "https://github.com/tienvx/composer-downloads-plugin",
            "no-api": true
        }
    ],
    "autoload": {
        "psr-4": {
            "PhpPact\\": "src/PhpPact"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "": "example/gen",
            "PhpPactTest\\": "tests/PhpPact",
            "Consumer\\": [
                "example/src/Consumer",
                "example/tests/Consumer"
            ],
            "MessageConsumer\\": [
                "example/src/MessageConsumer",
                "example/tests/MessageConsumer"
            ],
            "MessageProvider\\": [
                "example/src/MessageProvider",
                "example/tests/MessageProvider"
            ],
            "Provider\\": [
                "example/src/Provider"
            ]
        }
    },
    "scripts": {
        "post-update-cmd": [
            "\\PhpPact\\Standalone\\Scripts::makeStubServiceExecutable",
            "\\PhpPact\\Standalone\\Scripts::makeCsvPluginExecutable",
            "\\PhpPact\\Standalone\\Scripts::correctCsvPluginEntrypoint",
            "\\PhpPact\\Standalone\\Scripts::makeProtobufPluginExecutable",
            "\\PhpPact\\Standalone\\Scripts::correctProtobufPluginEntrypoint"
        ],
        "start-provider": "php -S localhost:58000 -t example/src/Provider/public/ example/src/Provider/public/proxy.php",
        "gen-proto": "protoc --php_out=example/gen example/proto/area_calculator.proto",
        "static-code-analysis": "phpstan analyse src/ --level=5 -c phpstan.neon",
        "lint": "php-cs-fixer fix --config .php-cs-fixer.php --dry-run",
        "fix": "php-cs-fixer fix --config .php-cs-fixer.php",
        "test": "phpunit --debug -c example/phpunit.all.xml"
    },
    "extra": {
        "downloads": {
            "pact-ruby-standalone": {
                "version": "1.91.0",
                "variables": {
                    "{$os}": "PHP_OS_FAMILY === 'Windows' ? 'win32' : (PHP_OS === 'Darwin' ? 'osx' : 'linux')",
                    "{$architecture}": "PHP_OS === 'Linux' ? '-x86_64' : ''",
                    "{$extension}": "PHP_OS_FAMILY === 'Windows' ? 'zip' : 'tar.gz'"
                },
                "url": "https://github.com/pact-foundation/pact-ruby-standalone/releases/download/v{$version}/pact-{$version}-{$os}{$architecture}.{$extension}",
                "path": "bin/pact-ruby-standalone"
            },
            "pact-ffi-headers": {
                "version": "0.3.14",
                "url": "https://github.com/pact-foundation/pact-reference/releases/download/libpact_ffi-v{$version}/pact.h",
                "path": "bin/pact-ffi-headers/pact.h"
            },
            "pact-stub-server": {
                "version": "0.5.2",
                "variables": {
                    "{$os}": "PHP_OS === 'Darwin' ? 'osx' : strtolower(PHP_OS_FAMILY)",
                    "{$extension}": "PHP_OS_FAMILY === 'Windows' ? 'exe.gz' : 'gz'"
                },
                "url": "https://github.com/pact-foundation/pact-stub-server/releases/download/v{$version}/pact-stub-server-{$os}-x86_64.{$extension}",
                "path": "bin/pact-stub-server"
            },
            "pact-ffi-lib": {
                "version": "0.3.14",
                "variables": {
                    "{$prefix}": "PHP_OS_FAMILY === 'Windows' ? 'pact_ffi' : 'libpact_ffi'",
                    "{$os}": "PHP_OS === 'Darwin' ? 'osx' : strtolower(PHP_OS_FAMILY)",
                    "{$architecture}": "php_uname('m') in ['arm64', 'aarch64'] ? (PHP_OS === 'Darwin' ? 'aarch64-apple-darwin' : 'aarch64') : 'x86_64'",
                    "{$extension}": "PHP_OS_FAMILY === 'Windows' ? 'dll.gz' : (PHP_OS === 'Darwin' ? 'dylib.gz' : 'so.gz')"
                },
                "url": "https://github.com/pact-foundation/pact-reference/releases/download/libpact_ffi-v{$version}/{$prefix}-{$os}-{$architecture}.{$extension}",
                "path": "bin/pact-ffi-lib"
            },
            "pact-csv-plugin-metadata": {
                "version": "0.0.3",
                "url": "https://github.com/pact-foundation/pact-plugins/releases/download/csv-plugin-{$version}/pact-plugin.json",
                "path": "bin/pact-plugins/csv/pact-plugin.json"
            },
            "pact-csv-plugin": {
                "version": "0.0.3",
                "variables": {
                    "{$os}": "PHP_OS === 'Darwin' ? 'osx' : strtolower(PHP_OS_FAMILY)",
                    "{$architecture}": "php_uname('m') in ['arm64', 'aarch64'] ? 'aarch64' : 'x86_64'",
                    "{$extension}": "PHP_OS_FAMILY === 'Windows' ? 'exe.gz' : 'gz'"
                },
                "url": "https://github.com/pact-foundation/pact-plugins/releases/download/csv-plugin-{$version}/pact-csv-plugin-{$os}-{$architecture}.{$extension}",
                "path": "bin/pact-plugins/csv/bin"
            },
            "pact-protobuf-plugin-metadata": {
                "version": "0.1.16",
                "url": "https://github.com/pactflow/pact-protobuf-plugin/releases/download/v-{$version}/pact-plugin.json",
                "path": "bin/pact-plugins/protobuf/pact-plugin.json"
            },
            "pact-protobuf-plugin": {
                "version": "0.1.16",
                "variables": {
                    "{$os}": "PHP_OS === 'Darwin' ? 'osx' : strtolower(PHP_OS_FAMILY)",
                    "{$architecture}": "php_uname('m') in ['arm64', 'aarch64'] ? 'aarch64' : 'x86_64'",
                    "{$extension}": "PHP_OS_FAMILY === 'Windows' ? 'exe.gz' : 'gz'"
                },
                "url": "https://github.com/pactflow/pact-protobuf-plugin/releases/download/v-{$version}/pact-protobuf-plugin-{$os}-{$architecture}.{$extension}",
                "path": "bin/pact-plugins/protobuf/bin"
            }
        }
    },
    "config": {
        "allow-plugins": {
            "civicrm/composer-downloads-plugin": true
        }
    }
}
